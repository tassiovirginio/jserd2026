{
  "$schema": "https://opencode.ai/config.json",
  "mcp": {
    "research-hub": {
      "type": "local",
      "command": ["rust-research-mcp"],
      "enabled": true,
      "environment": {
        "RUST_LOG": "info"
      }
    },
    "mcp-science": {
      "type": "local",
      "command": ["mcp-science", "web-fetch"],
      "enabled": true
    },
    "paper-search": {
      "type": "local",
      "command": ["paper-search-mcp-nodejs"],
      "enabled": true
    },
    "cite-mcp": {
      "type": "local",
      "command": ["cite-mcp"],
      "enabled": true
    }
  }
}
